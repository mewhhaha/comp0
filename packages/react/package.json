{
  "name": "@comp0/react",
  "version": "0.0.0",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./button": {
      "types": "./dist/button.d.ts",
      "default": "./dist/button.js"
    },
    "./dialog": {
      "types": "./dist/dialog.d.ts",
      "default": "./dist/dialog.js"
    },
    "./listbox": {
      "types": "./dist/listbox.d.ts",
      "default": "./dist/listbox.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && babel src --root-mode upward --extensions \".ts,.tsx\" --out-dir dist --ignore \"**/*.test.ts\" --ignore \"**/*.test.tsx\" && tsgo -p tsconfig.build.json",
    "typecheck": "tsgo -p tsconfig.json"
  },
  "dependencies": {
    "@comp0/core": "workspace:*"
  },
  "devDependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  }
}
