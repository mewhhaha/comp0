{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": false,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "tsBuildInfoFile": "./tsconfig.build.tsbuildinfo"
  },
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx"]
}
