{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "comp0-docs",
  "main": "@react-router/dev/config/default-rsc-entries/entry.rsc",
  "compatibility_date": "2026-07-12",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./build/client",
    "binding": "ASSETS"
  }
}
