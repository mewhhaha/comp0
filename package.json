{
  "name": "comp0",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev": "pnpm --filter @comp0/docs dev",
    "format": "oxfmt --write --ignore-path .oxfmtignore \"**/*.{ts,tsx,js,json,css,html,md,yaml}\"",
    "format:check": "oxfmt --check --ignore-path .oxfmtignore \"**/*.{ts,tsx,js,json,css,html,md,yaml}\"",
    "lint": "oxlint -c oxlint.json packages/core/src/*.ts packages/core/src/*.tsx packages/react/src/*.ts packages/react/src/*.tsx packages/react/test/*.tsx apps/docs/src/*.ts apps/docs/src/*.tsx apps/docs/vite.config.ts vitest.config.ts vitest.setup.ts --no-ignore",
    "test": "vitest run --project unit",
    "test:all": "vitest run",
    "test:browser": "vitest run --project browser",
    "typecheck": "tsgo -p tsconfig.typecheck.json"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260427.1",
    "@vitest/browser-playwright": "4.1.5",
    "eslint": "10.0.0",
    "eslint-plugin-better-tailwindcss": "4.4.1",
    "jsdom": "29.1.0",
    "oxfmt": "0.47.0",
    "oxlint": "1.62.0",
    "playwright": "1.58.1",
    "vite": "8.0.10",
    "vitest": "4.1.5"
  },
  "packageManager": "pnpm@10.33.2"
}
