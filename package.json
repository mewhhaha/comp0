{
  "name": "comp0",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev": "pnpm --filter @comp0/docs dev",
    "format": "oxfmt --write --ignore-path .oxfmtignore \"**/*.{ts,tsx,js,json,css,html,md,yaml}\"",
    "format:check": "oxfmt --check --ignore-path .oxfmtignore \"**/*.{ts,tsx,js,json,css,html,md,yaml}\"",
    "lint": "oxlint -c oxlint.config.ts packages/core/src/**/*.ts packages/core/src/**/*.tsx packages/react/src/**/*.ts packages/react/src/**/*.tsx packages/react/test/**/*.ts packages/react/test/**/*.tsx apps/docs/src/**/*.ts apps/docs/src/**/*.tsx apps/docs/vite.config.ts apps/docs/react-router.config.ts vitest.config.ts vitest.browser.setup.ts vitest.setup.ts --no-ignore --deny-warnings",
    "test": "vitest run --project unit",
    "test:all": "vitest run",
    "test:browser": "vitest run --project browser",
    "test:compiler-smoke": "pnpm build && node packages/react/test/verify-react-compiler.mjs",
    "test:package": "pnpm build && node scripts/verify-packages.mjs",
    "typecheck": "tsgo -p tsconfig.typecheck.json"
  },
  "devDependencies": {
    "@babel/cli": "^7.29.7",
    "@babel/core": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@types/node": "25.9.1",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260604.1",
    "@vitest/browser-playwright": "4.1.8",
    "axe-core": "^4.12.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint-plugin-better-tailwindcss": "4.5.0",
    "jsdom": "29.1.1",
    "oxfmt": "0.53.0",
    "oxlint": "1.68.0",
    "playwright": "1.60.0",
    "vite": "8.0.16",
    "vitest": "4.1.8"
  },
  "packageManager": "pnpm@11.5.1+sha512.93f7b57422ea7068257235b4c16eb60762eb68e1dc23723199cc739043ea9be2c4143274a399d8c6defa2b1176226d9ca1c4b63482d6200c1a8fbaa78c1d1485"
}
